{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm test*)",
      "Bash(npm run*)",
      "Bash(python3 scripts/*)",
      "Bash(bash scripts/*)",
      "Bash(node tests/*)",
      "Skill(create-issue *)",
      "Skill(start-issue *)",
      "Skill(close-issue *)",
      "Skill(review-pr *)",
      "Skill(new-runbook *)",
      "Skill(status)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: commit message must contain Refs DEMO-XXX'",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/stop_gate.sh 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
