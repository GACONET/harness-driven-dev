# Linear API key — get yours at: Linear → Settings → Security & access → New API key
# IMPORTANT: Create the key from the correct workspace (not a different one)
LINEAR_API_KEY=lin_api_your_key_here

# Linear team key — the prefix for your issue IDs
# Find it in Linear → Settings → Teams → your team's key (e.g., HAR, EXP, DEMO)
LINEAR_TEAM_KEY=DEMO

# GitHub Personal Access Token (PAT) — required for Layer 5 (PR Approval Gate)
# Scopes needed: repo (read), workflow (read). Generate at:
# https://github.com/settings/tokens?type=beta
# Note: `gh auth login` covers this for interactive use; this env var is for
# CI runners or non-interactive scripts that call `gh pr view --json reviewDecision`.
GITHUB_TOKEN=ghp_your_token_here
